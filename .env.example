# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (Gmail SMTP)
# For Gmail, use an app-specific password: https://myaccount.google.com/apppasswords
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Recipient Email Configuration
# This is where tailored resumes will be sent
# If not set, emails will use "recruiter@example.com" as placeholder
RECIPIENT_EMAIL=recruiter@example.com
